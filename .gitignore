# macOS
.DS_Store

# Secrets — never commit
.env
.env.*
.info
.info.*
*.p8
*.pem
*.key
secrets/
**/wrangler.toml.local

# Cloudflare Workers
.wrangler/
node_modules/
dist/
.dev.vars
.dev.vars.*
workers/*/node_modules/

# Xcode / Swift
ios/build/
ios/build-device/
ios/build-test/
ios/DerivedData/
ios/*.xcworkspace/xcuserdata/
ios/*.xcodeproj/xcuserdata/
ios/*.xcodeproj/project.xcworkspace/xcuserdata/
ios/**/*.xcuserstate
ios/.swiftpm/
.build/
Package.resolved

# Playwright MCP cache
.playwright-mcp/

# Xcode project is generated by xcodegen from project.yml — don't commit it
ios/*.xcodeproj/

# Logs / scratch
*.log
.cache/
tmp/
scratch/
