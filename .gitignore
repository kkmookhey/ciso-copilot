# macOS
.DS_Store

# Secrets — never commit
.env
.env.*
*.p8
*.pem
*.key
secrets/
**/wrangler.toml.local

# Cloudflare Workers
.wrangler/
node_modules/
dist/
.dev.vars
.dev.vars.*
workers/*/node_modules/

# Xcode / Swift
ios/build/
ios/DerivedData/
ios/*.xcworkspace/xcuserdata/
ios/*.xcodeproj/xcuserdata/
ios/*.xcodeproj/project.xcworkspace/xcuserdata/
ios/**/*.xcuserstate
ios/.swiftpm/
.build/
Package.resolved

# Xcode project is generated by xcodegen from project.yml — don't commit it
ios/*.xcodeproj/

# Logs / scratch
*.log
.cache/
tmp/
scratch/
