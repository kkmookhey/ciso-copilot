# macOS
.DS_Store

# Secrets — never commit
.env
.env.*
.info
.info.*
*.p8
*.pem
*.key
secrets/
**/wrangler.toml.local

# Web app per-environment Vite vars (template lives at web/.env.example)
web/.env
web/.env.local
web/.env.development
web/.env.production
# web/.env.test is INTENTIONALLY committed — placeholder URLs only,
# satisfies vitest module-load env-var guards.

# iOS local build config (template lives at ios/Local.xcconfig.example)
ios/Local.xcconfig

# Cloudflare Workers
.wrangler/
node_modules/
dist/
.dev.vars
.dev.vars.*
workers/*/node_modules/

# Xcode / Swift
ios/build/
ios/build-device/
ios/build-sim/
ios/build-test/
ios/DerivedData/
ios/*.xcworkspace/xcuserdata/
ios/*.xcodeproj/xcuserdata/
ios/*.xcodeproj/project.xcworkspace/xcuserdata/
ios/**/*.xcuserstate
ios/.swiftpm/
.build/
Package.resolved

# Playwright MCP cache
.playwright-mcp/

# Xcode project is generated by xcodegen from project.yml — don't commit it
ios/*.xcodeproj/

# Python
__pycache__/
*.pyc
.pytest_cache/

# Local-dev symlinks — vendored into Lambda zip by build.sh, not committed
platform/lambda/soc_enrichment/spend_cap.py

# build.sh-staged copies — docker build context only, not source of truth
platform/lambda/tools/_shared/

# ai_supply_chain_matcher build artifacts (produced by build.sh, not source)
platform/lambda/ai_supply_chain_matcher/_shared/
platform/lambda/ai_supply_chain_matcher/build/
platform/lambda/ai_supply_chain_matcher/dist/

# Logs / scratch
*.log
.cache/
tmp/
scratch/

# Superpowers brainstorm scratch + local test venv
.superpowers/
.venv-test/

# Claude Code local state
.claude/
